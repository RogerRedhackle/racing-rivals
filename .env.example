# Racing Rivals — demo environment (client-side)
# Copy the two values from Supabase → Project Settings → API.
# The ANON key is PUBLIC by design; RLS (migration 03) enforces access, not secrecy.
# NEVER put the service_role key here — it bypasses RLS and is backend-only.

RR_SUPABASE_URL=https://YOUR-DEMO-PROJECT.supabase.co
RR_SUPABASE_ANON_KEY=your-demo-anon-key

# --- How the static prototypes read these ------------------------------------
# The pages are plain HTML (no build step), so lib/config.js reads two globals:
#   window.__RR_SUPABASE_URL__
#   window.__RR_SUPABASE_ANON_KEY__
# For local/demo, set them before the module scripts load, e.g. add an inline
# <script> in the page head, or create an untracked lib/env.local.js:
#
#   window.__RR_SUPABASE_URL__      = 'https://YOUR-DEMO-PROJECT.supabase.co';
#   window.__RR_SUPABASE_ANON_KEY__ = 'your-demo-anon-key';
#
# When these are unset, lib/config.js.isConfigured() returns false and the auth
# guard stands down so the static demo still renders offline.
